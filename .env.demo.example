# Copy this to `.env` (in the same folder as docker-compose.yml) on the server
# and edit the values. Docker Compose reads `.env` automatically.

# --- Public address ---------------------------------------------------------
# Take your server's public IP and append ".nip.io" — this gives you a real
# hostname (that resolves to your IP) so Caddy can get a free HTTPS certificate
# WITHOUT you owning a domain.
#   Example: IP 129.146.10.20  ->  129.146.10.20.nip.io
SERVER_NAME=YOUR_PUBLIC_IP.nip.io
APP_URL=https://YOUR_PUBLIC_IP.nip.io

# Email used for the free Let's Encrypt certificate (any real address).
CADDY_EMAIL=you@example.com

# --- Database ---------------------------------------------------------------
# Fine to leave as-is for a throwaway demo; change them for anything real.
DB_DATABASE=urs_accounting
DB_USERNAME=urs_user
DB_PASSWORD=urs_demo_pw
DB_ROOT_PASSWORD=urs_root_pw
