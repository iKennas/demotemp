# Production environment template for URS backend.
# Copy the values below into Forge's site environment editor (or your
# host's env config) - do NOT commit a real .env.production file.
# Fill in every <PLACEHOLDER>.

APP_NAME=URS
APP_ENV=production
APP_KEY=                          # generate on server: php artisan key:generate --force
APP_DEBUG=false
APP_URL=https://api.<yourdomain>.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Forge provisions MySQL and fills these in automatically when you create
# the database via its UI - otherwise set them to match your DB.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=<forge_db_name>
DB_USERNAME=<forge_db_user>
DB_PASSWORD=<forge_db_password>

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=r2
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Resend (recommended - see PROJECT_MAP.md for why). Verify your sending
# domain in Resend before going live, or mail will land in spam/be rejected.
MAIL_MAILER=resend
RESEND_API_KEY=<resend_api_key>
MAIL_FROM_ADDRESS="noreply@<yourdomain>.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 (S3-compatible) - invoices/attachments/backups
R2_ACCESS_KEY_ID=<r2_access_key_id>
R2_SECRET_ACCESS_KEY=<r2_secret_access_key>
R2_BUCKET=<r2_bucket_name>
R2_URL=https://<r2_bucket_public_url>
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Moyasar (KSA payment gateway) - subscription billing.
# MOYASAR_WEBHOOK_SECRET must match the secret_token you configure in the
# Moyasar dashboard webhook URL (?secret_token=...) - see WebhookController.
MOYASAR_SECRET_KEY=<moyasar_secret_key>
MOYASAR_PUBLISHABLE_KEY=<moyasar_publishable_key>
MOYASAR_WEBHOOK_SECRET=<moyasar_webhook_secret>

# CORS: default config (allow all origins, no credentials) is safe and
# correct for this app - auth is Bearer-token only, never cookies, so
# there's no CSRF/credential-leak surface to restrict. No change needed.
